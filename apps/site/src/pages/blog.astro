---
import { getCollection } from "astro:content";
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import { getFormattedDate } from "@/utils/all";

const selectedTag = Astro.url.searchParams.get("tag");

const entries = (await getCollection("blog", ({ data }) => {
  const isNotDraft = !data.draft;
  if (selectedTag) {
    return isNotDraft && data.tags && data.tags.includes(selectedTag);
  }
  return isNotDraft;
})).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const blogUrl = new URL(Astro.url.pathname, Astro.site).toString();
const blogDescription =
  "EdgeEver 官方博客，记录 Cloudflare 自托管部署、印象笔记迁移、产品更新与 AI Agent 工作流。";

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "EdgeEver Blog",
  url: blogUrl,
  inLanguage: "zh-CN",
  description: blogDescription,
};
---

<Layout title="博客" description={blogDescription} jsonLd={blogJsonLd}>
  <Container>
    <main class="mx-auto max-w-4xl py-16 md:py-24">
      <div class="mb-10">
        <p class="text-sm font-semibold text-brand-text">EdgeEver Blog</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
          博客
        </h1>
      </div>

      <div class="grid gap-4">
        {
          entries.map((entry) => (
            <a
              href={`/blog/${entry.slug}`}
              class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-border hover:shadow-lg"
            >
              <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
                <span>{entry.data.category}</span>
                <span>·</span>
                <time datetime={entry.data.publishDate.toISOString()}>
                  {getFormattedDate(entry.data.publishDate)}
                </time>
              </div>
              <h2 class="mt-3 text-2xl font-bold text-slate-900 transition group-hover:text-brand-text">
                {entry.data.title}
              </h2>
              <p class="mt-3 text-base leading-7 text-slate-600">
                {entry.data.snippet}
              </p>
            </a>
          ))
        }
      </div>
    </main>
  </Container>
</Layout>
